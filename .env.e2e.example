# Copy to .env.e2e and adjust (optional — loads after .env.local in playwright.config.ts)

PLAYWRIGHT_BASE_URL=http://localhost:3000

# Must match PLAYWRIGHT_BASE_URL origin or NextAuth sign-in will fail locally
PLAYWRIGHT_NEXTAUTH_URL=http://localhost:3000

# Override admin used for setup (defaults to DEFAULT_ADMIN_* from .env.local)
# E2E_ADMIN_EMAIL=admin@hospital.com
# E2E_ADMIN_PASSWORD=admin123

# Skip Chromium PDF download test (combined IPD package) — faster CI or envs without Puppeteer deps
# E2E_SKIP_PDF=1
